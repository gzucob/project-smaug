# ==== brapi ====
# Token de autenticação (OBRIGATÓRIO). Gere em https://brapi.dev/dashboard
# NUNCA commite o .env real — este arquivo é apenas o modelo.
BRAPI_TOKEN=
BRAPI_BASE_URL=https://brapi.dev/api

# ==== MongoDB (Docker Compose local) ====
MONGO_URI=mongodb://localhost:27017
MONGO_DB=smaug

# ==== Coleta ====
# Pausa entre requisições (segundos) para respeitar o rate limit da brapi
REQUEST_DELAY_SECONDS=2
