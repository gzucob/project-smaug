# ==== Fonte de dados ====
# Fonte ativa da ingestão: "cvm" (padrão) ou "brapi". Só UMA por vez.
# Trocar aqui basta — as duas usam a mesma porta, sem reescrever código.
INGESTION_SOURCE=cvm

# ==== CVM ====
# Ano do arquivo ITR a espelhar (baixado de dados.cvm.gov.br). 2024 é o padrão.
CVM_YEAR=2024

# ==== brapi ====
# Token de autenticação (só necessário quando INGESTION_SOURCE=brapi).
# Gere em https://brapi.dev/dashboard. NUNCA commite o .env real.
BRAPI_TOKEN=
BRAPI_BASE_URL=https://brapi.dev/api

# ==== MongoDB (Docker Compose local) ====
MONGO_URI=mongodb://localhost:27017
MONGO_DB=smaug

# ==== Coleta ====
# Pausa entre requisições (segundos) para respeitar o rate limit da brapi
REQUEST_DELAY_SECONDS=2
